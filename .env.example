LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-5.4

# Backward-compatible OpenRouter names are still supported.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5.4

# Required only for HR retrieval/workflow runs in llm mode.
OPENROUTER_EMBEDDING_MODEL=

# Documentation-only default for HR prototype examples; CLI/API flags still choose mode.
HR_SIMULATION_MODE=mock

PREPPER_DEFAULT_SYSTEM_PROMPT=coding_focus
